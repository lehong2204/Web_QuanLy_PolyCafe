                    <td>
                        <span class="@(u.IsActive ? "badge-green" : "badge-red")" id="active-badge-@u.Id">
                            @(u.IsActive ? "Hoạt động" : "Bị khoá")
                        </span>
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <button class="btn-adm btn-adm-ghost" style="font-size:11px;padding:5px 10px"
                                    onclick="openEdit('@u.Id')" title="Chỉnh sửa">
                                <i class="fa fa-pen"></i>
                            </button>
                            <button class="btn-adm btn-adm-ghost" style="font-size:11px;padding:5px 10px"
                                    onclick="toggleRole('@u.Id')" title="Đổi role">
                                <i class="fa fa-shield-halved"></i>
                            </button>
                            <button class="btn-adm @(u.IsActive ? "btn-adm-red" : "btn-adm-green")"
                                    style="font-size:11px;padding:5px 10px"
                                    onclick="toggleActive('@u.Id')"
                                    title="@(u.IsActive ? "Khoá" : "Mở khoá")"
                                    id="active-btn-@u.Id">
                                <i class="fa @(u.IsActive ? "fa-lock" : "fa-lock-open")"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ================================================================ -->
<!-- MODAL THÊM / SỬA TÀI KHOẢN                                       -->
<!-- ================================================================ -->
<div id="user-modal-overlay"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;
            align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:14px;width:100%;max-width:480px;
                padding:28px 32px;box-shadow:0 8px 40px rgba(0,0,0,.18);position:relative">

        <button onclick="closeModal()"
                style="position:absolute;top:14px;right:18px;background:none;border:none;
                       font-size:20px;cursor:pointer;color:#94a3b8">
            ✕
        </button>

        <h5 id="modal-title" style="font-weight:700;margin-bottom:20px;color:#1e293b">
            Thêm tài khoản
        </h5>

        <input type="hidden" id="modal-id" />

        <div class="mb-3">
            <label style="font-size:13px;font-weight:600;color:#374151">
                Họ tên <span style="color:red">*</span>
            </label>
            <input id="modal-fullname" class="adm-input" style="width:100%;margin-top:4px"
                   placeholder="Nhập họ tên..." />
        </div>

        <div class="mb-3">
            <label style="font-size:13px;font-weight:600;color:#374151">
                Email <span style="color:red">*</span>
            </label>
            <input id="modal-email" type="email" class="adm-input" style="width:100%;margin-top:4px"
                   placeholder="Nhập email..." />
        </div>

        <div class="mb-3">
            <label style="font-size:13px;font-weight:600;color:#374151">Số điện thoại</label>
            <input id="modal-phone" class="adm-input" style="width:100%;margin-top:4px"
                   placeholder="Nhập SĐT..." />
        </div>

        <div class="mb-3">
            <label style="font-size:13px;font-weight:600;color:#374151">Địa chỉ</label>
            <input id="modal-address" class="adm-input" style="width:100%;margin-top:4px"
                   placeholder="Nhập địa chỉ..." />
        </div>

        <div class="mb-3" id="modal-password-wrap">
            <label style="font-size:13px;font-weight:600;color:#374151">
                <span id="modal-pass-label">Mật khẩu</span>
                <span style="color:red" id="modal-pass-required"> *</span>
            </label>
            <input id="modal-password" type="password" class="adm-input"
                   style="width:100%;margin-top:4px"
                   placeholder="Nhập mật khẩu (tối thiểu 6 ký tự)..." />
            <small id="modal-pass-hint" style="color:#94a3b8;font-size:11px;display:none">
                Để trống nếu không muốn thay đổi mật khẩu
            </small>
        </div>

        <div class="mb-3" id="modal-role-wrap">
            <label style="font-size:13px;font-weight:600;color:#374151">Vai trò</label>
            <select id="modal-role" class="adm-input" style="width:100%;margin-top:4px">
                <option value="false">Staff</option>
                <option value="true">Admin</option>
            </select>
        </div>

        <div id="modal-error"
             style="display:none;background:#fee2e2;color:#dc2626;padding:8px 12px;
                    border-radius:8px;font-size:13px;margin-bottom:12px"></div>

        <div class="d-flex gap-2 justify-content-end mt-3">
            <button class="btn-adm btn-adm-ghost" onclick="closeModal()">Huỷ</button>
            <button class="btn-adm btn-adm-primary" id="modal-submit-btn" onclick="submitModal()">
                <i class="fa fa-floppy-disk me-1"></i> Lưu
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const overlay = document.getElementById('user-modal-overlay');

        // ================================================================
        // OPEN / CLOSE MODAL
        // ================================================================
        function closeModal() {
            overlay.style.display = 'none';
        }

        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeModal();
        });

        function openCreate() {
            document.getElementById('modal-title').textContent              = 'Thêm tài khoản mới';
            document.getElementById('modal-id').value                      = '';
            document.getElementById('modal-fullname').value                = '';
            document.getElementById('modal-email').value                   = '';
            document.getElementById('modal-phone').value                   = '';
            document.getElementById('modal-address').value                 = '';
            document.getElementById('modal-password').value                = '';
            document.getElementById('modal-role').value                    = 'false';
            document.getElementById('modal-pass-label').textContent        = 'Mật khẩu';
            document.getElementById('modal-pass-required').style.display   = 'inline';
            document.getElementById('modal-pass-hint').style.display       = 'none';
            document.getElementById('modal-password-wrap').style.display   = 'block';
            document.getElementById('modal-role-wrap').style.display       = 'block';
            document.getElementById('modal-error').style.display           = 'none';
            overlay.style.display = 'flex';
        }

        async function openEdit(id) {
            const r = await fetch('/Admin/User/GetById?id=' + id);
            const d = await r.json();
            if (!d.success) { admToast('Không tải được thông tin!', false); return; }

            document.getElementById('modal-title').textContent              = 'Cập nhật tài khoản';
            document.getElementById('modal-id').value                      = d.id;
            document.getElementById('modal-fullname').value                = d.fullName;
            document.getElementById('modal-email').value                   = d.email;
            document.getElementById('modal-phone').value                   = d.phone;
            document.getElementById('modal-address').value                 = d.address;
            document.getElementById('modal-password').value                = '';
            document.getElementById('modal-role').value                    = d.role.toString();
            document.getElementById('modal-pass-label').textContent        = 'Mật khẩu mới';
            document.getElementById('modal-pass-required').style.display   = 'none';
            document.getElementById('modal-pass-hint').style.display       = 'inline';
            document.getElementById('modal-role-wrap').style.display       = 'none';
            document.getElementById('modal-error').style.display           = 'none';

            // Chỉ Admin mới thấy ô đổi mật khẩu
            document.getElementById('modal-password-wrap').style.display   = d.role ? 'block' : 'none';

            overlay.style.display = 'flex';
        }

        // ================================================================
        // SUBMIT MODAL
        // ================================================================
        async function submitModal() {
            const id     = document.getElementById('modal-id').value;
            const isEdit = !!id;
            const errBox = document.getElementById('modal-error');
            errBox.style.display = 'none';

            const payload = {
                id:          id,
                fullName:    document.getElementById('modal-fullname').value.trim(),
                email:       document.getElementById('modal-email').value.trim(),
                phone:       document.getElementById('modal-phone').value.trim(),
                address:     document.getElementById('modal-address').value.trim(),
                password:    document.getElementById('modal-password').value,
                newPassword: document.getElementById('modal-password').value,
                role:        document.getElementById('modal-role').value === 'true'
            };

            const url = isEdit ? '/Admin/User/Update' : '/Admin/User/Create';
            const btn = document.getElementById('modal-submit-btn');
            btn.disabled  = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i> Đang lưu...';

            const r = await fetch(url, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            });
            const d = await r.json();

            btn.disabled  = false;
            btn.innerHTML = '<i class="fa fa-floppy-disk me-1"></i> Lưu';

            if (!d.success) {
                errBox.textContent   = d.message || 'Có lỗi xảy ra!';
                errBox.style.display = 'block';
                return;
            }

            if (isEdit) {
                document.getElementById('name-'  + id).textContent = d.fullName;
                document.getElementById('email-' + id).textContent = d.email;
                document.getElementById('phone-' + id).textContent = d.phone;
                admToast('Cập nhật tài khoản thành công!');
            } else {
                const tbody = document.getElementById('user-tbody');
                const tr    = document.createElement('tr');
                tr.id = 'user-row-' + d.id;
                tr.innerHTML = `
                    <td style="font-weight:800">
                        <div class="d-flex align-items-center gap-2">
                            <div style="width:32px;height:32px;border-radius:50%;
                                        background:${d.role==='Admin'?'#ede9fe':'#dbeafe'};
                                        display:flex;align-items:center;justify-content:center;font-size:13px">
                                ${d.role==='Admin'?'👑':'👤'}
                            </div>
                            <span id="name-${d.id}">${d.fullName}</span>
                        </div>
                    </td>
                    <td style="font-size:12px;color:#64748b" id="email-${d.id}">${d.email}</td>
                    <td style="font-size:12px" id="phone-${d.id}">${d.phone}</td>
                    <td><span class="${d.role==='Admin'?'badge-purple':'badge-blue'}"
                              id="role-badge-${d.id}">${d.role}</span></td>
                    <td style="font-size:12px;color:#94a3b8">${d.createdAt}</td>
                    <td><span class="badge-green" id="active-badge-${d.id}">Hoạt động</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <button class="btn-adm btn-adm-ghost" style="font-size:11px;padding:5px 10px"
                                    onclick="openEdit('${d.id}')" title="Chỉnh sửa">
                                <i class="fa fa-pen"></i></button>
                            <button class="btn-adm btn-adm-ghost" style="font-size:11px;padding:5px 10px"
                                    onclick="toggleRole('${d.id}')" title="Đổi role">
                                <i class="fa fa-shield-halved"></i></button>
                            <button class="btn-adm btn-adm-red" style="font-size:11px;padding:5px 10px"
                                    onclick="toggleActive('${d.id}')" title="Khoá"
                                    id="active-btn-${d.id}">
                                <i class="fa fa-lock"></i></button>
                        </div>
                    </td>`;
                tbody.appendChild(tr);

                const countEl = document.getElementById('user-count');
                countEl.textContent = (parseInt(countEl.textContent) + 1) + ' tài khoản';
                admToast('Thêm tài khoản thành công!');
            }

            closeModal();
        }

        // ================================================================
        // TOGGLE ACTIVE / ROLE
        // ================================================================
        async function toggleActive(id) {
            const r = await fetch('/Admin/User/ToggleActive', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:    `id=${id}`
            });
            const d = await r.json();
            if (!d.success) { admToast(d.message || 'Lỗi!', false); return; }

            const badge = document.getElementById('active-badge-' + id);
            const btn   = document.getElementById('active-btn-'   + id);
            if (d.isActive) {
                badge.className = 'badge-green'; badge.textContent = 'Hoạt động';
                btn.className   = 'btn-adm btn-adm-red';
                btn.style.cssText = 'font-size:11px;padding:5px 10px';
                btn.innerHTML   = '<i class="fa fa-lock"></i>';
            } else {
                badge.className = 'badge-red'; badge.textContent = 'Bị khoá';
                btn.className   = 'btn-adm btn-adm-green';
                btn.style.cssText = 'font-size:11px;padding:5px 10px';
                btn.innerHTML   = '<i class="fa fa-lock-open"></i>';
            }
            admToast(d.isActive ? 'Đã mở khoá' : 'Đã khoá tài khoản');
        }

        async function toggleRole(id) {
            if (!confirm('Thay đổi vai trò tài khoản này?')) return;
            const r = await fetch('/Admin/User/ToggleRole', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:    `id=${id}`
            });
            const d = await r.json();
            if (!d.success) { admToast(d.message || 'Lỗi!', false); return; }

            const badge = document.getElementById('role-badge-' + id);
            badge.className   = d.role === 'Admin' ? 'badge-purple' : 'badge-blue';
            badge.textContent = d.role;
            admToast('Đã đổi role thành ' + d.role);
        }
    </script>
}