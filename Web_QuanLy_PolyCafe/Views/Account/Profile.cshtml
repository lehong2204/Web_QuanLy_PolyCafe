        }

        /* CARD */
        .pf-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 1px 6px rgba(0,0,0,.07);
            overflow: hidden;
        }

        .pf-card-head {
            padding: 13px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .pf-card-title {
            font-family: 'Playfair Display',serif;
            font-size: 15px;
            color: #1e293b;
            font-weight: 700;
        }

        .pf-card-body {
            padding: 18px 20px;
        }

        /* FORM */
        .pf-lbl {
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            margin-bottom: 5px;
            display: block;
        }

        .pf-ctrl {
            width: 100%;
            padding: 9px 12px;
            border: 1.5px solid var(--border);
            border-radius: 9px;
            font-size: 13px;
            font-family: 'Nunito',sans-serif;
            color: #1e293b;
            background: #fff;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }

            .pf-ctrl:focus {
                border-color: var(--amber);
                box-shadow: 0 0 0 3px rgba(245,158,11,.12);
            }

            .pf-ctrl:disabled {
                background: #f8fafc;
                color: #94a3b8;
                cursor: not-allowed;
            }

        .pf-pw-wrap {
            position: relative;
        }

            .pf-pw-wrap .pf-ctrl {
                padding-right: 40px;
            }

        .pf-pw-eye {
            position: absolute;
            right: 11px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #94a3b8;
            font-size: 13px;
            transition: color .1s;
        }

            .pf-pw-eye:hover {
                color: var(--amber);
            }

        /* BUTTON */
        .pf-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 18px;
            border-radius: 9px;
            font-size: 12px;
            font-weight: 800;
            font-family: 'Nunito',sans-serif;
            border: none;
            cursor: pointer;
            transition: all .13s;
        }

        .pf-btn-amber {
            background: var(--amber);
            color: #fff;
        }

            .pf-btn-amber:hover {
                background: var(--amber2);
            }

        /* ALERT */
        .pf-alert {
            display: none;
            padding: 10px 14px;
            border-radius: 9px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 12px;
            align-items: center;
            gap: 8px;
        }

            .pf-alert.show {
                display: flex;
            }

        .pf-alert-ok {
            background: #d1fae5;
            color: #065f46;
        }

        .pf-alert-err {
            background: #fee2e2;
            color: #991b1b;
        }

        /* INFO ROWS */
        .pf-irow {
            display: flex;
            align-items: flex-start;
            padding: 10px 0;
            border-bottom: 1px solid #f8fafc;
            gap: 12px;
        }

            .pf-irow:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .pf-irow:first-child {
                padding-top: 0;
            }

        .pf-iico {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: #fef3c7;
            color: var(--amber2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            flex-shrink: 0;
        }

        .pf-ilbl {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .pf-ival {
            font-size: 13px;
            color: #1e293b;
            font-weight: 700;
            word-break: break-word;
