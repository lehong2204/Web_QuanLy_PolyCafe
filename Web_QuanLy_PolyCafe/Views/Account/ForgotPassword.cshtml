@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="monkey-wrap">
    <div style="font-size:48px;text-align:center;margin-bottom:12px">🔑</div>
    <h4 class="text-center fw-semibold mb-1">Quên mật khẩu?</h4>
    <p class="text-center text-muted small mb-4">
        Nhập email đăng ký — chúng tôi sẽ gửi mật khẩu mới ngay cho bạn.
    </p>

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success text-center py-2 mb-3" id="success-box">
            <i class="bi bi-envelope-check me-1"></i>@ViewBag.Success
            <div class="mt-2" style="font-size:13px;color:#374151">
                Tự động chuyển về đăng nhập sau
                <strong id="countdown">6</strong> giây...
            </div>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center py-2 mb-3">
            <i class="bi bi-exclamation-circle me-1"></i>@ViewBag.Error
        </div>
    }

    @if (ViewBag.Success == null)
    {
        <form method="post" asp-controller="Account" asp-action="ForgotPassword">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">
                    Email <span class="text-danger">*</span>
                </label>
                <input name="email"
                       type="email"
                       class="form-control"
                       placeholder="Nhập email đăng ký"
                       required />
            </div>
            <button type="submit" class="btn btn-main w-100 mb-3">
                <i class="bi bi-send me-1"></i> Gửi mật khẩu mới
            </button>
            <div class="text-center">
                <a asp-controller="Account" asp-action="Login"
                   class="text-decoration-none small text-secondary">
                    ← Quay lại đăng nhập
                </a>
            </div>
        </form>
    }
</div>

@if (ViewBag.Success != null)
{
    <script>
        let seconds = 6;
        const countdownEl = document.getElementById('countdown');
        const timer = setInterval(() => {
            seconds--;
            countdownEl.textContent = seconds;
            if (seconds <= 0) {
                clearInterval(timer);
                window.location.href = '@Url.Action("Login", "Account")';
            }
        }, 1000);
    </script>
}