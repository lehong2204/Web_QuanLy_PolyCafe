
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    :root {
        --sz-avatar: 130px;
        --sz-svg: calc(var(--sz-avatar) - 10px);
    }

    #blind-input-login {
        display: none;
    }

    .monkey-avatar {
        display: flex;
        justify-content: center;
        align-items: center;
        width: var(--sz-avatar);
        height: var(--sz-avatar);
        border-radius: 9999px;
        border: 2px solid #d0bfb4;
        background: #fdf6f0;
        margin: 0 auto 20px auto;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        perspective: 80px;
        transition: box-shadow 0.2s;
    }

        .monkey-avatar:hover {
            box-shadow: 0 4px 18px rgba(137,102,76,0.22);
        }

        .monkey-avatar svg {
            position: absolute;
            transition: transform 0.22s ease, opacity 0.15s;
            transform-origin: 50% 100%;
            height: var(--sz-svg);
            width: var(--sz-svg);
            pointer-events: none;
        }

            .monkey-avatar svg#monkey-face {
                z-index: 1;
            }

            /* Tay ở dưới (ẩn) theo mặc định */
            .monkey-avatar svg#monkey-hands {
                z-index: 2;
                transform-style: preserve-3d;
                transform: translateY(calc(var(--sz-avatar) / 1.25)) rotateX(-21deg);
            }

        /* Miệng */
        .monkey-avatar::before {
            content: "";
            border-radius: 45%;
            width: calc(var(--sz-svg) / 3.889);
            height: calc(var(--sz-svg) / 5.833);
            border: 0;
            border-bottom: calc(var(--sz-svg) * 0.04) solid #3c302a;
            bottom: 20%;
            position: absolute;
            transition: all 0.22s ease;
            z-index: 3;
        }

        /* Mắt chớp */
        .monkey-avatar svg#monkey-face .eye-r,
        .monkey-avatar svg#monkey-face .eye-l {
            animation: monkeyBlink 10s 1s infinite;
            transition: all 0.2s ease;
        }

    @@keyframes monkeyBlink {
        0%, 2%, 4%, 26%, 28%, 71%, 73%, 100% {
            ry: 4.5;
            cy: 31.7;
        }

        1%, 3%, 27%, 72% {
            ry: 0.5;
            cy: 30;
        }
    }

    /* ===== VẪYYYY TAY CHÀO: tay kéo THẲNG LÊN ĐẦU, lắc qua lại ===== */
    .monkey-avatar svg#monkey-hands {
        animation: waveHello 2.4s ease 0.5s 1 forwards;
    }

    @@keyframes waveHello {
        /* Bắt đầu: tay ẩn dưới */
        0% {
            transform: translateY(calc(var(--sz-avatar) / 1.25)) rotateX(-21deg) rotate(0deg);
        }
        /* Kéo thẳng lên trên đầu */
        18% {
            transform: translateY(-30%) rotateX(0deg) rotate(0deg);
        }
        /* Lắc sang trái */
        30% {
            transform: translateY(-30%) rotateX(0deg) rotate(-20deg);
        }
        /* Lắc sang phải */
        42% {
            transform: translateY(-30%) rotateX(0deg) rotate(20deg);
        }
        /* Lắc trái */
        54% {
            transform: translateY(-30%) rotateX(0deg) rotate(-18deg);
        }
        /* Lắc phải */
        64% {
            transform: translateY(-30%) rotateX(0deg) rotate(16deg);
        }
        /* Về giữa */
        72% {
            transform: translateY(-30%) rotateX(0deg) rotate(0deg);
        }
        /* Hạ tay xuống */
        100% {
            transform: translateY(calc(var(--sz-avatar) / 1.25)) rotateX(-21deg) rotate(0deg);
        }
    }

    /* Khi checked: tay che mắt */
    #blind-input-login:checked ~ .monkey-wrap .monkey-avatar svg#monkey-hands {
        animation: none !important;
        transform: translate3d(0, 0, 0) rotateX(0deg) !important;
    }

    /* Khi unchecked: tay về dưới */
    #blind-input-login:not(:checked) ~ .monkey-wrap .monkey-avatar svg#monkey-hands {
        transform: translateY(calc(var(--sz-avatar) / 1.25)) rotateX(-21deg);
    }

    /* Miệng tròn khi checked */
    #blind-input-login:checked ~ .monkey-wrap .monkey-avatar::before {
        width: calc(var(--sz-svg) * 0.09);
        height: 0;
        border-radius: 50%;
        border-bottom: calc(var(--sz-svg) * 0.10) solid #3c302a;
    }

    /* Mắt nhắm khi checked */
    #blind-input-login:checked ~ .monkey-wrap .monkey-avatar svg#monkey-face .eye-r,
    #blind-input-login:checked ~ .monkey-wrap .monkey-avatar svg#monkey-face .eye-l {
        ry: 0.5;
        cy: 30;
    }
</style>

<input type="checkbox" id="blind-input-login" />

<div class="monkey-wrap">

    <label for="blind-input-login" class="monkey-avatar" title="Nhấn để ẩn/hiện mật khẩu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" id="monkey-face">
            <ellipse cx="53.7" cy="33" rx="8.3" ry="8.2" fill="#89664c" />
            <ellipse cx="53.7" cy="33" rx="5.4" ry="5.4" fill="#ffc5d3" />
            <ellipse cx="10.2" cy="33" rx="8.2" ry="8.2" fill="#89664c" />
            <ellipse cx="10.2" cy="33" rx="5.4" ry="5.4" fill="#ffc5d3" />
            <g fill="#89664c">
                <path d="m43.4 10.8c1.1-.6 1.9-.9 1.9-.9-3.2-1.1-6-1.8-8.5-2.1 1.3-1 2.1-1.3 2.1-1.3-20.4-2.9-30.1 9-30.1 19.5h46.4c-.7-7.4-4.8-12.4-11.8-15.2" />
                <path d="m55.3 27.6c0-9.7-10.4-17.6-23.3-17.6s-23.3 7.9-23.3 17.6c0 2.3.6 4.4 1.6 6.4-1 2-1.6 4.2-1.6 6.4 0 9.7 10.4 17.6 23.3 17.6s23.3-7.9 23.3-17.6c0-2.3-.6-4.4-1.6-6.4 1-2 1.6-4.2 1.6-6.4" />
            </g>
            <path d="m52 28.2c0-16.9-20-6.1-20-6.1s-20-10.8-20 6.1c0 4.7 2.9 9 7.5 11.7-1.3 1.7-2.1 3.6-2.1 5.7 0 6.1 6.6 11 14.7 11s14.7-4.9 14.7-11c0-2.1-.8-4-2.1-5.7 4.4-2.7 7.3-7 7.3-11.7" fill="#e0ac7e" />
            <g fill="#3b302a">
                <path d="m35.1 38.7c0 1.1-.4 2.1-1 2.1-.6 0-1-.9-1-2.1 0-1.1.4-2.1 1-2.1.6.1 1 1 1 2.1" />
                <path d="m30.9 38.7c0 1.1-.4 2.1-1 2.1-.6 0-1-.9-1-2.1 0-1.1.4-2.1 1-2.1.5.1 1 1 1 2.1" />
                <ellipse cx="40.7" cy="31.7" rx="3.5" ry="4.5" class="eye-r" />
                <ellipse cx="23.3" cy="31.7" rx="3.5" ry="4.5" class="eye-l" />
            </g>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" id="monkey-hands">
            <path fill="#89664C" d="M9.4,32.5L2.1,61.9H14c-1.6-7.7,4-21,4-21L9.4,32.5z" />
            <path fill="#FFD6BB" d="M15.8,24.8c0,0,4.9-4.5,9.5-3.9c2.3,0.3-7.1,7.6-7.1,7.6s9.7-8.2,11.7-5.6c1.8,2.3-8.9,9.8-8.9,9.8s10-8.1,9.6-4.6c-0.3,3.8-7.9,12.8-12.5,13.8C11.5,43.2,6.3,39,9.8,24.4" />
            <path fill="#89664C" d="M54.8,32.5l7.3,29.4H50.2c1.6-7.7-4-21-4-21L54.8,32.5z" />
            <path fill="#FFD6BB" d="M48.4,24.8c0,0-4.9-4.5-9.5-3.9c-2.3,0.3,7.1,7.6,7.1,7.6s-9.7-8.2-11.7-5.6c-1.8,2.3,8.9,9.8,8.9,9.8s-10-8.1-9.7-4.6c0.4,3.8,8,12.8,12.6,13.8c6.6,1.3,11.8-2.9,8.3-17.5" />
        </svg>
    </label>

    <h4 class="text-center fw-semibold mb-4">Đăng nhập</h4>

    <form method="post" asp-controller="Account" asp-action="Login">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">
                Email / Số điện thoại <span class="text-danger">*</span>
            </label>
            <input name="email"
                   class="form-control"
                   placeholder="Email hoặc số điện thoại"
                   value="@ViewBag.Email"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-medium">
                Mật khẩu <span class="text-danger">*</span>
            </label>
            <div class="input-group">
                <input id="password"
                       name="password"
                       type="password"
                       class="form-control"
                       placeholder="Mật khẩu"
                       required />
                <span class="input-group-text bg-white"
                      style="cursor:pointer"
                      id="togglePassword">
                    <i class="bi bi-eye-slash"></i>
                </span>
            </div>
        </div>

        <div class="text-end mb-3">
            <a href="#" class="text-decoration-none small text-danger">Quên mật khẩu?</a>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 text-center mb-3" role="alert">
                <i class="bi bi-exclamation-circle me-1"></i>@ViewBag.Error
            </div>
        }

        <button type="submit" class="btn btn-main w-100 mb-3">
            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
        </button>
    </form>

</div>

<script>
    const togglePassword = document.getElementById("togglePassword");
    const passwordInput  = document.getElementById("password");
    const eyeIcon        = togglePassword.querySelector("i");
    const checkbox       = document.getElementById("blind-input-login");

    function syncEyeIcon() {
        const isHidden = passwordInput.type === "password";
        eyeIcon.classList.toggle("bi-eye",       !isHidden);
        eyeIcon.classList.toggle("bi-eye-slash",  isHidden);
    }

    togglePassword.addEventListener("click", function () {
        checkbox.checked = !checkbox.checked;
        passwordInput.type = checkbox.checked ? "password" : "text";
        syncEyeIcon();
    });

    checkbox.addEventListener("change", function () {
        passwordInput.type = this.checked ? "password" : "text";
        syncEyeIcon();
    });
</script>
