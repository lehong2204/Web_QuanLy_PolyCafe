@section Scripts {
    <script>
        // ===== DỮ LIỆU =====
        const POS_DRINKS = @Html.Raw(drinksJson);
        const POS_CATS   = @Html.Raw(catsJson);

        // Emoji + màu nền theo categoryId
        const POS_EMOJI = {
            'CAT01':'☕','CAT02':'🧋','CAT03':'🥤','CAT04':'🍊','CAT05':'🍑',
            'CAT06':'🍵','CAT07':'🍫','CAT08':'🧊','CAT09':'🫧','CAT10':'☕',
            'CAT11':'☕','CAT12':'☕','CAT13':'🧊','CAT14':'🥛','CAT15':'🍓',
            'CAT16':'🌸','CAT17':'🍦','CAT18':'🥥','CAT19':'🍋','CAT20':'⭐'
        };
        const POS_BG = {
            'CAT01':'#fef3c7','CAT02':'#fce7f3','CAT03':'#d1fae5','CAT04':'#fff7ed',
            'CAT05':'#ffe4e6','CAT06':'#d1fae5','CAT07':'#fdf2f8','CAT08':'#dbeafe',
            'CAT09':'#ecfdf5','CAT10':'#fef9c3','CAT11':'#fde68a','CAT12':'#fef3c7',
            'CAT13':'#dbeafe','CAT14':'#fce7f3','CAT15':'#ffe4e6','CAT16':'#fdf4ff',
            'CAT17':'#f5f3ff','CAT18':'#f0fdf4','CAT19':'#fef9c3','CAT20':'#fffbeb'
        };
        const CAT_ICON = {
            'Cà Phê':'fa-coffee','Trà Sữa':'fa-mug-hot','Sinh Tố':'fa-blender',
            'Nước Ép':'fa-droplet','Trà Trái Cây':'fa-leaf','Matcha':'fa-seedling',
            'Chocolate':'fa-candy-bar','Đá Xay':'fa-snowflake','Soda':'fa-flask',
            'Latte':'fa-coffee','Cappuccino':'fa-coffee','Espresso':'fa-fire',
            'Cold Brew':'fa-temperature-low','Yogurt':'fa-jar','Hoa Quả Dầm':'fa-bowl-food',
            'Trà Hoa':'fa-spa','Kem':'fa-ice-cream','Nước Dừa':'fa-tree',
            'Chanh Muối':'fa-lemon','Đặc Biệt':'fa-star'
        };

        let posCurCat = 'all';

        // ===== BUILD CATEGORY BAR =====
        (function() {
            const bar = document.getElementById('pos-cats');
            POS_CATS.forEach(c => {
                const ic = CAT_ICON[c.name] || 'fa-mug-hot';
                const b = document.createElement('button');
                b.className = 'pos-cat-btn';
                b.dataset.cat = c.id;
                b.innerHTML = `<i class="fa ${ic}"></i>${c.name}`;
                b.onclick = function() { posCat(this); };
                bar.appendChild(b);
            });
        })();

        function posCat(btn) {
            document.querySelectorAll('.pos-cat-btn').forEach(x => x.classList.remove('active'));
            btn.classList.add('active');
            posCurCat = btn.dataset.cat;
            posRender();
        }

        // ===== RENDER SẢN PHẨM =====
        function posRender() {
            const q = document.getElementById('pos-search').value.toLowerCase();
            const list = POS_DRINKS.filter(d =>
                (posCurCat === 'all' || d.catId === posCurCat) &&
                (d.name.toLowerCase().includes(q) || d.desc.toLowerCase().includes(q))
            );
            const g = document.getElementById('pos-grid');
            g.innerHTML = '';

