
        @model IEnumerable<Web_QuanLy_PolyCafe.Models.Drink>
        @{
            ViewData["Title"] = "Đặt Món";
            Layout = "~/Views/Shared/_Layout.cshtml";

            var categories = ViewBag.Categories as IEnumerable<Web_QuanLy_PolyCafe.Models.Category>
                             ?? Enumerable.Empty<Web_QuanLy_PolyCafe.Models.Category>();

            var drinksJson = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => new
            {
                id = d.Id,
                name = d.Name,
                desc = d.Description ?? "",
                price = d.Price,
                catId = d.CategoryId,
                catName = d.Category?.Name ?? "",
                img = string.IsNullOrEmpty(d.ImageUrl) ? "" : d.ImageUrl,
                available = d.IsAvailable,
                variants = (d.DrinkVariants ?? new List<Web_QuanLy_PolyCafe.Models.DrinkVariant>())
                            .Where(v => v.IsActive)
                            .Select(v => new { id = v.Id, name = v.VariantName, extra = v.ExtraPrice })
            }));

            var catsJson = System.Text.Json.JsonSerializer.Serialize(
                categories.Select(c => new { id = c.Id, name = c.Name })
            );
        }

        @section HeadStyles {
            <style>
                .pos-wrap {
                    display: flex;
                    flex-direction: column;
                    height: 100%;
                    overflow: hidden;
                }

                /* SEARCH */
                .pos-search {
                    background: #fff;
                    border-bottom: 1px solid var(--border);
                    flex-shrink: 0;
                    padding: 9px 14px;
                }

                .pos-search-inner {
                    position: relative;
                }

                    .pos-search-inner input {
                        width: 100%;
                        padding: 8px 12px 8px 36px;
                        border: 1.5px solid var(--border);
                        border-radius: 9px;
                        font-size: 13px;
                        font-family: 'Nunito',sans-serif;
                        color: #1e293b;
                        background: var(--bg);
                        outline: none;
                        transition: all .15s;
                    }

                        .pos-search-inner input:focus {
                            border-color: var(--amber);
                            background: #fff;
                        }

                    .pos-search-inner .fa {
                        position: absolute;
                        left: 12px;
                        top: 50%;
                        transform: translateY(-50%);
                        color: #94a3b8;
                        font-size: 13px;
                    }

                /* CATS */
                .pos-cats {
                    background: #fff;
                    border-bottom: 1px solid var(--border);
                    flex-shrink: 0;
                    padding: 8px 14px;
                    display: flex;
                    gap: 6px;
                    overflow-x: auto;
                }

                    .pos-cats::-webkit-scrollbar {
                        display: none;
                    }

                .pos-cat-btn {
                    border: 1.5px solid var(--border);
                    background: #fff;
                    border-radius: 20px;
                    padding: 5px 14px;
                    font-size: 12px;
                    font-weight: 700;
                    color: #64748b;
                    cursor: pointer;
                    white-space: nowrap;
                    font-family: 'Nunito',sans-serif;
                    transition: all .13s;
                    display: flex;
                    align-items: center;
                    gap: 5px;
                }

                    .pos-cat-btn.active {
                        background: #1e293b;
                        color: #fff;
                        border-color: #1e293b;
                    }

                    .pos-cat-btn:hover:not(.active) {
                        border-color: var(--amber);
                        color: var(--amber2);
                    }

                /* GRID */
                .pos-grid-wrap {
                    flex: 1;
                    overflow-y: scroll !important;
                    -webkit-overflow-scrolling: touch;
                    padding: 12px 14px;
                }

                    .pos-grid-wrap::-webkit-scrollbar {
                        width: 5px;
                    }

                    .pos-grid-wrap::-webkit-scrollbar-thumb {
                        background: #cbd5e1;
                        border-radius: 4px;
                    }

                /* CARD */
                .pos-p-card {
                    background: #fff;
                    border-radius: 14px;
                    border: 2px solid transparent;
                    cursor: pointer;
                    transition: all .15s;
                    box-shadow: 0 1px 4px rgba(0,0,0,.07);
                    overflow: hidden;
                    position: relative;
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                }

                    .pos-p-card:hover {
                        border-color: var(--amber);
                        box-shadow: 0 4px 14px rgba(245,158,11,.15);
                        transform: translateY(-2px);
                    }

                    .pos-p-card:active {
                        transform: scale(.97);
                    }

                /* ẢNH: object-fit cover đúng tỉ lệ */
                .pos-p-img {
                    width: 100%;
                    height: 120px;
                    position: relative;
                    overflow: hidden;
                    flex-shrink: 0;
                    background: #f1f5f9;
                }

                    .pos-p-img > img {
                        position: absolute;
                        inset: 0;
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        object-position: center;
                        display: block;
                    }

                    .pos-p-img > .emoji-wrap {
                        position: absolute;
                        inset: 0;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 42px;
                    }

                /* Badge số lượng */
                .pos-p-qbadge {
                    position: absolute;
                    top: 7px;
                    left: 7px;
                    z-index: 3;
                    background: var(--green);
                    color: #fff;
                    font-size: 10px;
                    font-weight: 800;
                    width: 20px;
                    height: 20px;
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 2px 6px rgba(16,185,129,.4);
                }

                /* BODY */
                .pos-p-body {
                    padding: 10px 11px 11px;
                    flex: 1;
                    display: flex;
                    flex-direction: column;
                }

                .pos-p-name {
                    font-size: 13px;
                    font-weight: 800;
                    color: #1e293b;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    margin-bottom: 2px;
                }

                .pos-p-desc {
                    font-size: 11px;
                    color: #94a3b8;
                    margin-bottom: 8px;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    flex: 1;
                }

                .pos-p-price {
                    font-size: 14px;
                    font-weight: 800;
                    color: var(--amber2);
                }

                /* NÚT + và nút info */
                .pos-p-add {
                    width: 26px;
                    height: 26px;
                    background: #1e293b;
                    color: #fff;
                    border: none;
                    border-radius: 8px;
                    font-size: 13px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    transition: background .12s;
                    flex-shrink: 0;
                }

                    .pos-p-add:hover {
                        background: var(--amber);
                    }

                .pos-p-info {
                    width: 26px;
                    height: 26px;
                    background: #f1f5f9;
                    color: #64748b;
                    border: 1.5px solid var(--border);
                    border-radius: 8px;
                    font-size: 11px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    transition: all .12s;
                    flex-shrink: 0;
                }

                    .pos-p-info:hover {
                        background: #e0f2fe;
                        color: #0284c7;
                        border-color: #7dd3fc;
                    }

                /* ===== MODAL CHI TIẾT ===== */
                .pos-detail-overlay {
                    display: none;
                    position: fixed;
                    inset: 0;
                    background: rgba(0,0,0,.45);
                    z-index: 1050;
                    align-items: center;
                    justify-content: center;
                }

                    .pos-detail-overlay.show {
                        display: flex;
                    }

                .pos-detail-modal {
                    background: #fff;
                    border-radius: 20px;
                    width: 420px;
                    max-width: 90vw;
                    box-shadow: 0 20px 60px rgba(0,0,0,.25);
                    overflow: hidden;
                    animation: modalIn .2s ease;
                }
                @@keyframes modalIn {
                    from

                {
                    opacity: 0;
                    transform: scale(.94) translateY(12px);
                }

                to {
                    opacity: 1;
                    transform: scale(1) translateY(0);
                }

                }

                .pos-dm-img {
                    width: 100%;
                    height: 200px;
                    object-fit: cover;
                    object-position: center;
                    display: block;
                    background: #f1f5f9;
                }

                .pos-dm-emoji {
                    width: 100%;
                    height: 200px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 72px;
                }

                .pos-dm-body {
                    padding: 20px 22px 24px;
                }

                .pos-dm-cat {
                    font-size: 11px;
                    font-weight: 800;
                    color: var(--amber2);
                    background: var(--cream);
                    padding: 3px 10px;
                    border-radius: 20px;
                    display: inline-block;
                    margin-bottom: 10px;
                }

                .pos-dm-name {
                    font-family: 'Playfair Display',serif;
                    font-size: 20px;
                    color: #1e293b;
                    font-weight: 700;
                    margin-bottom: 6px;
                }

                .pos-dm-desc {
                    font-size: 13px;
                    color: #64748b;
                    line-height: 1.6;
                    margin-bottom: 14px;
                }

                .pos-dm-price {
                    font-family: 'Playfair Display',serif;
                    font-size: 26px;
                    color: var(--amber2);
                    font-weight: 700;
                    margin-bottom: 14px;
                }

                .pos-dm-variants {
                    margin-bottom: 16px;
                }

                .pos-dm-var-title {
                    font-size: 12px;
                    font-weight: 800;
                    color: #94a3b8;
                    margin-bottom: 7px;
                }

                .pos-dm-var-list {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 6px;
                }

                .pos-dm-var-tag {
                    font-size: 11px;
                    font-weight: 700;
                    padding: 4px 11px;
                    border-radius: 20px;
                    border: 1.5px solid var(--border);
                    color: #64748b;
                    background: #fff;
                    cursor: pointer;
                    transition: all .12s;
                }

                    .pos-dm-var-tag:hover, .pos-dm-var-tag.sel {
                        border-color: var(--amber);
                        background: var(--cream);
                        color: var(--amber2);
                    }

                .pos-dm-footer {
                    display: flex;
                    gap: 10px;
                }

                .pos-dm-close {
                    flex-shrink: 0;
                    padding: 10px 18px;
                    border-radius: 9px;
                    background: #f1f5f9;
                    color: #64748b;
                    border: none;
                    font-size: 12px;
                    font-weight: 800;
                    font-family: 'Nunito',sans-serif;
                    cursor: pointer;
                    transition: background .12s;
                }

                    .pos-dm-close:hover {
                        background: #e2e8f0;
                    }

                .pos-dm-order {
                    flex: 1;
                    padding: 10px 18px;
                    border-radius: 9px;
                    background: var(--amber);
                    color: #fff;
                    border: none;
                    font-size: 12px;
                    font-weight: 800;
                    font-family: 'Nunito',sans-serif;
                    cursor: pointer;
                    transition: background .12s;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 7px;
                }

                    .pos-dm-order:hover {
                        background: var(--amber2);
                    }

                /* Tag không khả dụng */
                .pos-p-unavail {
                    position: absolute;
                    top: 7px;
                    right: 7px;
                    z-index: 3;
                    background: rgba(239,68,68,.9);
                    color: #fff;
                    font-size: 9px;
                    font-weight: 800;
                    padding: 2px 8px;
                    border-radius: 10px;
                }
            </style>
        }

        <div class="pos-wrap">
            <div class="pos-search">
                <div class="pos-search-inner">
                    <i class="fa fa-magnifying-glass"></i>
                    <input id="pos-search" placeholder="Tìm kiếm món..." oninput="posFilter()" />
                </div>
            </div>

            <div class="pos-cats" id="pos-cats">
                <button class="pos-cat-btn active" data-cat="all" onclick="posCat(this)">
                    <i class="fa fa-border-all"></i>Tất cả
                </button>
            </div>

            <div class="pos-grid-wrap">
                <div class="row g-2" id="pos-grid"></div>
            </div>
        </div>

        <!-- ===== MODAL CHI TIẾT ĐỒ UỐNG ===== -->
        <div class="pos-detail-overlay" id="posDetailOverlay" onclick="posCloseDetail(event)">
            <div class="pos-detail-modal" id="posDetailModal">
                <div id="pos-dm-img-wrap"></div>
                <div class="pos-dm-body">
                    <div id="pos-dm-cat" class="pos-dm-cat"></div>
                    <div id="pos-dm-name" class="pos-dm-name"></div>
                    <div id="pos-dm-desc" class="pos-dm-desc"></div>
                    <div id="pos-dm-price" class="pos-dm-price"></div>
                    <div id="pos-dm-variants" class="pos-dm-variants" style="display:none">
                        <div class="pos-dm-var-title"><i class="fa fa-sliders me-1"></i>Tuỳ chọn size / topping</div>
                        <div id="pos-dm-var-list" class="pos-dm-var-list"></div>
                    </div>
                    <div class="pos-dm-footer">
                        <button class="pos-dm-close" onclick="posCloseDetailBtn()"><i class="fa fa-arrow-left me-1"></i>Đóng</button>
                        <button class="pos-dm-order" id="pos-dm-order-btn"><i class="fa fa-plus"></i>Thêm vào đơn</button>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            <script>
                const POS_DRINKS = @Html.Raw(drinksJson);
                const POS_CATS   = @Html.Raw(catsJson);

                const POS_BG = {
                    'CAT01':'#fef3c7','CAT02':'#fce7f3','CAT03':'#d1fae5','CAT04':'#fff7ed',
                    'CAT05':'#ffe4e6','CAT06':'#d1fae5','CAT07':'#fdf2f8','CAT08':'#dbeafe',
                    'CAT09':'#ecfdf5','CAT10':'#fef9c3','CAT11':'#fde68a','CAT12':'#fef3c7',
                    'CAT13':'#dbeafe','CAT14':'#fce7f3','CAT15':'#ffe4e6','CAT16':'#fdf4ff',
                    'CAT17':'#f5f3ff','CAT18':'#f0fdf4','CAT19':'#fef9c3','CAT20':'#fffbeb'
                };
                const POS_EMOJI = {
                    'CAT01':'☕','CAT02':'🧋','CAT03':'🥤','CAT04':'🍊','CAT05':'🍑',
                    'CAT06':'🍵','CAT07':'🍫','CAT08':'🧊','CAT09':'🫧','CAT10':'☕',
                    'CAT11':'☕','CAT12':'☕','CAT13':'🧊','CAT14':'🥛','CAT15':'🍓',
                    'CAT16':'🌸','CAT17':'🍦','CAT18':'🥥','CAT19':'🍋','CAT20':'⭐'
                };

                let posCurCat = 'all';
                let posDetailDrink = null;
                let posDetailSelVarId = null, posDetailSelVarExtra = 0, posDetailSelVarName = '';

                /* Build category bar */
                (function buildCatBar() {
                    const bar = document.getElementById('pos-cats');
                    POS_CATS.forEach(c => {
                        const b = document.createElement('button');
                        b.className = 'pos-cat-btn';
                        b.dataset.cat = c.id;
                        b.innerHTML = `<i class="fa fa-mug-hot"></i>${c.name}`;
                        b.onclick = function() { posCat(this); };
                        bar.appendChild(b);
                    });
                })();

                function posCat(btn) {
                    document.querySelectorAll('.pos-cat-btn').forEach(x => x.classList.remove('active'));
                    btn.classList.add('active');
                    posCurCat = btn.dataset.cat;
                    posRender();
                }

                function posRender() {
                    const q = document.getElementById('pos-search').value.toLowerCase();
                    const list = POS_DRINKS.filter(d =>
                        (posCurCat === 'all' || d.catId === posCurCat) &&
                        (d.name.toLowerCase().includes(q) || d.desc.toLowerCase().includes(q))
                    );
                    const g = document.getElementById('pos-grid');
                    g.innerHTML = '';

                    list.forEach(d => {
                        const bg    = POS_BG[d.catId]    || '#f1f5f9';
                        const emoji = POS_EMOJI[d.catId] || '☕';
                        const qty   = posGetQty(d.id);

                        let imgHtml = '';
                        if (d.img) {
                            imgHtml = `
                                <img src="/images/drinks/${d.img}" alt="${d.name}"
                                     onload="this.nextElementSibling.style.display='none';"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <span class="emoji-wrap" style="background:${bg};">${emoji}</span>`;
                        } else {
                            imgHtml = `<span class="emoji-wrap" style="background:${bg};">${emoji}</span>`;
                        }

                        const col = document.createElement('div');
                        col.className = 'col-2 pos-col';
                        col.dataset.id = d.id;
                        col.innerHTML = `
                            <div class="pos-p-card" onclick="posClick('${d.id}')">
                                <div class="pos-p-img" style="background:${bg};">
                                    ${imgHtml}
                                    <span class="pos-p-qbadge" id="pos-qb-${d.id}" style="display:${qty?'flex':'none'}">${qty}</span>
                                    ${!d.available ? '<span class="pos-p-unavail">Hết hàng</span>' : ''}
                                </div>
                                <div class="pos-p-body">
                                    <div class="pos-p-name">${d.name}</div>
                                    <div class="pos-p-desc">${d.desc || '&nbsp;'}</div>
                                    <div class="d-flex justify-content-between align-items-center gap-1">
                                        <span class="pos-p-price">${Number(d.price).toLocaleString('vi')}đ</span>
                                        <div class="d-flex gap-1">
                                            <button class="pos-p-info" onclick="event.stopPropagation();posOpenDetail('${d.id}')" title="Chi tiết">
                                                <i class="fa fa-circle-info"></i>
                                            </button>
                                            <button class="pos-p-add" onclick="event.stopPropagation();posClick('${d.id}')" title="Thêm vào đơn">
                                                <i class="fa fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        g.appendChild(col);
                    });
                }

                function posFilter() { posRender(); }

                function posClick(id) {
                    const d = POS_DRINKS.find(x => x.id === id);
                    if (!d || !d.available) return;
                    const bg    = POS_BG[d.catId]    || '#f1f5f9';
                    const emoji = POS_EMOJI[d.catId] || '☕';
                    pcCardClick(d.id, d.name, d.price, d.variants, bg, emoji, d.img);
                }

                function posGetQty(id) {
                    return Object.entries(pcCart)
                        .filter(([k]) => k.startsWith(id))
                        .reduce((a, [, v]) => a + v.qty, 0);
                }

                function pcOnCartChange(changedId) {
                    POS_DRINKS.forEach(d => {
                        const b = document.getElementById('pos-qb-' + d.id);
                        if (!b) return;
                        const qty = posGetQty(d.id);
                        if (qty > 0) { b.style.display = 'flex'; b.textContent = qty; }
                        else b.style.display = 'none';
                    });
                }

                /* ===== MODAL CHI TIẾT ===== */
                function posOpenDetail(id) {
                    const d = POS_DRINKS.find(x => x.id === id);
                    if (!d) return;
                    posDetailDrink = d;
                    posDetailSelVarId = null; posDetailSelVarExtra = 0; posDetailSelVarName = '';

                    const bg    = POS_BG[d.catId]    || '#f1f5f9';
                    const emoji = POS_EMOJI[d.catId] || '☕';

                    /* Ảnh hoặc emoji */
                    const imgWrap = document.getElementById('pos-dm-img-wrap');
                    if (d.img) {
                        imgWrap.innerHTML = `
                            <img class="pos-dm-img" src="/images/drinks/${d.img}" alt="${d.name}"
                                 onerror="this.outerHTML='<div class=\\'pos-dm-emoji\\' style=\\'background:${bg}\\'>${emoji}</div>'" />`;
                    } else {
                        imgWrap.innerHTML = `<div class="pos-dm-emoji" style="background:${bg}">${emoji}</div>`;
                    }

                    document.getElementById('pos-dm-cat').textContent   = d.catName || '';
                    document.getElementById('pos-dm-name').textContent  = d.name;
                    document.getElementById('pos-dm-desc').textContent  = d.desc || 'Chưa có mô tả.';
                    document.getElementById('pos-dm-price').textContent = Number(d.price).toLocaleString('vi') + 'đ';

                    /* Variants */
                    const varWrap = document.getElementById('pos-dm-variants');
                    const varList = document.getElementById('pos-dm-var-list');
                    if (d.variants && d.variants.length > 0) {
                        varList.innerHTML = '';
                        /* Tag mặc định */
                        const defTag = document.createElement('span');
                        defTag.className = 'pos-dm-var-tag sel';
                        defTag.textContent = `Mặc định — ${Number(d.price).toLocaleString('vi')}đ`;
                        defTag.onclick = () => {
                            varList.querySelectorAll('.pos-dm-var-tag').forEach(t => t.classList.remove('sel'));
                            defTag.classList.add('sel');
                            posDetailSelVarId = null; posDetailSelVarExtra = 0; posDetailSelVarName = '';
                            document.getElementById('pos-dm-price').textContent = Number(d.price).toLocaleString('vi') + 'đ';
                        };
                        varList.appendChild(defTag);

                        d.variants.forEach(v => {
                            const tag = document.createElement('span');
                            tag.className = 'pos-dm-var-tag';
                            tag.textContent = `${v.name} +${Number(v.extra).toLocaleString('vi')}đ`;
                            tag.onclick = () => {
                                varList.querySelectorAll('.pos-dm-var-tag').forEach(t => t.classList.remove('sel'));
                                tag.classList.add('sel');
                                posDetailSelVarId    = v.id;
                                posDetailSelVarExtra = v.extra;
                                posDetailSelVarName  = v.name;
                                document.getElementById('pos-dm-price').textContent =
                                    Number(d.price + v.extra).toLocaleString('vi') + 'đ';
                            };
                            varList.appendChild(tag);
                        });
                        varWrap.style.display = 'block';
                    } else {
                        varWrap.style.display = 'none';
                    }

                    /* Nút thêm vào đơn */
                    const orderBtn = document.getElementById('pos-dm-order-btn');
                    if (!d.available) {
                        orderBtn.disabled = true;
                        orderBtn.style.opacity = '.5';
                        orderBtn.style.cursor  = 'not-allowed';
                    } else {
                        orderBtn.disabled = false;
                        orderBtn.style.opacity = '1';
                        orderBtn.style.cursor  = 'pointer';
                    }
                    orderBtn.onclick = () => posDetailAddToCart();

                    document.getElementById('posDetailOverlay').classList.add('show');
                }

                function posDetailAddToCart() {
                    if (!posDetailDrink || !posDetailDrink.available) return;
                    const d  = posDetailDrink;
                    const bg = POS_BG[d.catId] || '#f1f5f9';
                    const emoji = POS_EMOJI[d.catId] || '☕';
                    pcAddToCart(d.id, d.name, Number(d.price) + posDetailSelVarExtra,
                                posDetailSelVarId, posDetailSelVarName, bg, emoji, d.img);
                    posCloseDetailBtn();
                }

                function posCloseDetailBtn() {
                    document.getElementById('posDetailOverlay').classList.remove('show');
                }

                function posCloseDetail(e) {
                    if (e.target === document.getElementById('posDetailOverlay')) posCloseDetailBtn();
                }

                posRender();
            </script>
        }




