            'Cold Brew':'fa-temperature-low','Yogurt':'fa-jar','Hoa Quả Dầm':'fa-bowl-food',
            'Trà Hoa':'fa-spa','Kem':'fa-ice-cream','Nước Dừa':'fa-tree',
            'Chanh Muối':'fa-lemon','Đặc Biệt':'fa-star'
        };

        let posCurCat = 'all';

        // ===== BUILD CATEGORY BAR =====
        (function() {
            const bar = document.getElementById('pos-cats');
