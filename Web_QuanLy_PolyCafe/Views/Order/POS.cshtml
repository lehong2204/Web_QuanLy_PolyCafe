@* @model IEnumerable<Web_QuanLy_PolyCafe.Models.Drink>
@{
    ViewData["Title"] = "Đặt Món";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categories = ViewBag.Categories as IEnumerable<Web_QuanLy_PolyCafe.Models.Category>
                     ?? Enumerable.Empty<Web_QuanLy_PolyCafe.Models.Category>();

    var drinksJson = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => new
    {
        id = d.Id,
        name = d.Name,
        desc = d.Description ?? "",
        price = d.Price,
        catId = d.CategoryId,
        img = string.IsNullOrEmpty(d.ImageUrl) ? "" : d.ImageUrl,
        variants = (d.DrinkVariants ?? new List<Web_QuanLy_PolyCafe.Models.DrinkVariant>())
                    .Where(v => v.IsActive)
                    .Select(v => new { id = v.Id, name = v.VariantName, extra = v.ExtraPrice })
    }));

    var catsJson = System.Text.Json.JsonSerializer.Serialize(
        categories.Select(c => new { id = c.Id, name = c.Name })
    );
}

@section HeadStyles {
    <style>
        .pos-wrap {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }

        .pos-search {
            background: #fff;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            padding: 9px 14px;
        }

        .pos-search-inner {
            position: relative;
        }

            .pos-search-inner input {
                width: 100%;
                padding: 8px 12px 8px 36px;
                border: 1.5px solid var(--border);
                border-radius: 9px;
                font-size: 13px;
                font-family: 'Nunito', sans-serif;
                color: #1e293b;
                background: var(--bg);
                outline: none;
                transition: all .15s;
            }

                .pos-search-inner input:focus {
                    border-color: var(--amber);
                    background: #fff;
                }

            .pos-search-inner .fa {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 13px;
            }

        .pos-cats {
            background: #fff;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            padding: 8px 14px;
            display: flex;
            gap: 6px;
            overflow-x: auto;
        }

            .pos-cats::-webkit-scrollbar {
                display: none;
            }

        .pos-cat-btn {
            border: 1.5px solid var(--border);
            background: #fff;
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            cursor: pointer;
            white-space: nowrap;
            font-family: 'Nunito', sans-serif;
            transition: all .13s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .pos-cat-btn.active {
                background: #1e293b;
                color: #fff;
                border-color: #1e293b;
            }

            .pos-cat-btn:hover:not(.active) {
                border-color: var(--amber);
                color: var(--amber2);
            }

        .pos-grid-wrap {
            flex: 1;
            overflow-y: scroll !important;
            -webkit-overflow-scrolling: touch;
            padding: 12px 14px;
        }

            .pos-grid-wrap::-webkit-scrollbar {
                width: 5px;
            }

            .pos-grid-wrap::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 4px;
            }

        .pos-p-card {
            background: #fff;
            border-radius: 14px;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all .15s;
            box-shadow: 0 1px 4px rgba(0,0,0,.07);
            overflow: hidden;
            position: relative;
            height: 100%;
        }

            .pos-p-card:hover {
                border-color: var(--amber);
                box-shadow: 0 4px 14px rgba(245,158,11,.15);
                transform: translateY(-2px);
            }

            .pos-p-card:active {
                transform: scale(.97);
            }

        /* ✅ FIX ẢNH: khung cố định, ảnh fill đầy, không bị méo */
        .pos-p-img {
            height: 120px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .pos-p-img img {
                width: 100%;
                height: 100%;
                object-fit: cover; /* ảnh fill đầy khung, crop phần thừa */
                object-position: center;
                display: block;
                position: absolute;
                top: 0;
                left: 0;
            }

            .pos-p-img .emoji-fallback {
                font-size: 42px;
                z-index: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                width: 100%;
                height: 100%;
            }

        .pos-p-qbadge {
            position: absolute;
            top: 7px;
            left: 7px;
            background: var(--green);
            color: #fff;
            font-size: 10px;
            font-weight: 800;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 6px rgba(16,185,129,.4);
            z-index: 2;
        }

        .pos-p-body {
            padding: 10px 11px 11px;
        }

        .pos-p-name {
            font-size: 13px;
            font-weight: 800;
            color: #1e293b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 2px;
        }

        .pos-p-desc {
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 8px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .pos-p-price {
            font-size: 14px;
            font-weight: 800;
            color: var(--amber2);
        }

        .pos-p-add {
            width: 26px;
            height: 26px;
            background: #1e293b;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background .12s;
            flex-shrink: 0;
        }

            .pos-p-add:hover {
                background: var(--amber);
            }
    </style>
}

