@* @model IEnumerable<Web_QuanLy_PolyCafe.Models.Drink>
@{
    ViewData["Title"] = "Đặt Món - PolyCafe POS";
    Layout = null; // Full-screen POS, không dùng layout mặc định
    var categories = ViewBag.Categories as IEnumerable<Web_QuanLy_PolyCafe.Models.Category> ?? Enumerable.Empty<Web_QuanLy_PolyCafe.Models.Category>();
    var vouchers = ViewBag.Vouchers as IEnumerable<Web_QuanLy_PolyCafe.Models.Voucher> ?? Enumerable.Empty<Web_QuanLy_PolyCafe.Models.Voucher>();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --amber: #f59e0b;
            --amber2: #d97706;
            --green: #10b981;
            --red: #ef4444;
            --sb: #1e293b;
            --sb2: #273548;
            --bg: #f1f5f9;
            --cream: #fef3c7;
            --border: #e2e8f0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; overflow: hidden; font-family: 'Nunito', sans-serif; background: var(--bg); }

        /* === TOPBAR === */
        .topbar {
            height: 54px;
            background: #fff;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            z-index: 100;
        }
        .logo-box { width: 34px; height: 34px; background: var(--amber); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 17px; }
        .brand-name { font-family: 'Playfair Display', serif; font-size: 16px; color: #1e293b; }
        .pos-tag { background: var(--cream); color: var(--amber2); font-size: 10px; font-weight: 800; padding: 2px 8px; border-radius: 20px; }
        .clock-box { background: var(--bg); padding: 5px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; color: #1e293b; }
        .staff-box { background: var(--bg); padding: 5px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; color: #1e293b; }
        .staff-dot { width: 7px; height: 7px; background: var(--green); border-radius: 50%; }
        .bill-toggle-btn {
            background: #1e293b; color: #fff; border: none; border-radius: 9px;
            padding: 6px 14px; font-size: 12px; font-weight: 700; font-family: 'Nunito', sans-serif;
            display: flex; align-items: center; gap: 7px; cursor: pointer; transition: background .15s; position: relative;
        }
        .bill-toggle-btn:hover { background: #334155; }
        .bill-badge {
            background: var(--amber); color: #fff; font-size: 9px; font-weight: 800;
            width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
            position: absolute; top: -5px; right: -5px;
        }

        /* === LAYOUT === */
        .app-body { height: calc(100vh - 54px); display: flex; overflow: hidden; }
        .left-col { display: flex; flex-direction: column; flex: 1; min-width: 0; overflow: hidden; }
        .toolbar-wrap { background: #fff; border-bottom: 1px solid var(--border); flex-shrink: 0; padding: 9px 14px; }
        .search-wrap { position: relative; }
        .search-wrap input {
            width: 100%; padding: 8px 12px 8px 36px; border: 1.5px solid var(--border);
            border-radius: 9px; font-size: 13px; font-family: 'Nunito', sans-serif; color: #1e293b;
            background: var(--bg); outline: none; transition: all .15s;
        }
        .search-wrap input:focus { border-color: var(--amber); background: #fff; }
        .search-wrap .fa { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 13px; }

        /* === CATEGORY BAR === */
        .cat-bar {
            background: #fff; border-bottom: 1px solid var(--border); flex-shrink: 0;
            padding: 8px 14px; display: flex; gap: 6px; overflow-x: auto;
        }
        .cat-bar::-webkit-scrollbar { display: none; }
        .cat-btn {
            border: 1.5px solid var(--border); background: #fff; border-radius: 20px;
            padding: 5px 14px; font-size: 12px; font-weight: 700; color: #64748b;
            cursor: pointer; white-space: nowrap; font-family: 'Nunito', sans-serif;
            transition: all .13s; display: flex; align-items: center; gap: 5px;
        }
        .cat-btn.active { background: #1e293b; color: #fff; border-color: #1e293b; }
        .cat-btn:hover:not(.active) { border-color: var(--amber); color: var(--amber2); }

        /* === PRODUCT GRID === */
        .product-scroll { flex: 1; overflow-y: scroll !important; -webkit-overflow-scrolling: touch; padding: 12px 14px; }
        .product-scroll::-webkit-scrollbar { width: 5px; }
        .product-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

        .p-card {
            background: #fff; border-radius: 12px; border: 2px solid transparent;
            cursor: pointer; transition: all .15s; box-shadow: 0 1px 4px rgba(0,0,0,.07);
            overflow: hidden; position: relative; height: 100%;
        }
        .p-card:hover { border-color: var(--amber); box-shadow: 0 4px 14px rgba(245,158,11,.15); transform: translateY(-1px); }
        .p-card:active { transform: scale(.97); }
        .p-img { height: 72px; display: flex; align-items: center; justify-content: center; font-size: 30px; position: relative; }
        .p-tag { position: absolute; top: 6px; right: 6px; background: var(--amber); color: #fff; font-size: 9px; font-weight: 800; padding: 2px 6px; border-radius: 14px; }
        .p-qty-badge {
            position: absolute; top: 5px; left: 5px; background: var(--green); color: #fff;
            font-size: 9px; font-weight: 800; width: 18px; height: 18px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
        }
        .p-body { padding: 7px 9px 9px; }
        .p-name { font-size: 12px; font-weight: 800; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 1px; }
        .p-desc { font-size: 10px; color: #94a3b8; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .p-price { font-size: 13px; font-weight: 800; color: var(--amber2); }
        .p-add-btn {
            width: 23px; height: 23px; background: #1e293b; color: #fff; border: none;
            border-radius: 7px; font-size: 13px; display: flex; align-items: center;
            justify-content: center; cursor: pointer; transition: background .12s; flex-shrink: 0;
        }
        .p-add-btn:hover { background: var(--amber); }

        /* === SIDEBAR === */
        .sidebar {
            width: 285px; background: var(--sb); display: flex; flex-direction: column;
            flex-shrink: 0; overflow: hidden; transition: width .35s cubic-bezier(.4,0,.2,1);
        }
        .sidebar.hidden { width: 0; }
        .sb-inner { display: flex; flex-direction: column; height: 100%; min-width: 285px; }
        .sb-head { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,.08); flex-shrink: 0; }
        .sb-title { font-family: 'Playfair Display', serif; color: #fff; font-size: 15px; }
        .sb-num { background: var(--amber); color: #fff; font-size: 10px; font-weight: 800; padding: 2px 8px; border-radius: 16px; }

        .order-scroll {
            flex: 1; overflow-y: scroll !important; -webkit-overflow-scrolling: touch;
            padding: 8px; display: flex; flex-direction: column; gap: 5px; min-height: 0;
        }
        .order-scroll::-webkit-scrollbar { width: 3px; }
        .order-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 2px; }

        .empty-bill { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; color: rgba(255,255,255,.18); font-size: 12px; padding: 40px 0; flex: 1; }
        .empty-bill i { font-size: 32px; opacity: .15; }

        .oi {
            background: var(--sb2); border: 1px solid rgba(255,255,255,.07); border-radius: 9px;
            padding: 9px 10px; display: flex; align-items: center; gap: 8px;
            animation: up .2s ease;
        }
        @@keyframes up { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        .oi:hover { border-color: rgba(245,158,11,.3); }
        .oi-em { width: 30px; height: 30px; border-radius: 8px; background: #fff1; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
        .oi-name { color: #fff; font-size: 11px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .oi-sub { color: rgba(255,255,255,.4); font-size: 10px; }
        .oi-price { color: var(--amber); font-size: 10px; font-weight: 600; margin-top: 1px; }

        .qbtn {
            width: 20px; height: 20px; border: 1px solid rgba(255,255,255,.12); background: transparent;
            color: rgba(255,255,255,.6); border-radius: 5px; cursor: pointer; font-size: 12px;
            display: flex; align-items: center; justify-content: center; transition: all .1s;
        }
        .qbtn:hover { background: var(--amber); border-color: var(--amber); color: #fff; }
        .qnum { color: #fff; font-size: 12px; font-weight: 800; min-width: 16px; text-align: center; }
        .del-btn { background: transparent; border: none; color: rgba(255,80,80,.4); cursor: pointer; font-size: 14px; padding: 0 2px; transition: color .1s; }
        .del-btn:hover { color: var(--red); }

        /* === FOOTER === */
        .sb-foot { padding: 11px 13px; border-top: 1px solid rgba(255,255,255,.08); flex-shrink: 0; }
        .coup-in {
            background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1); border-radius: 7px;
            padding: 7px 9px; color: #fff; font-size: 11px; outline: none;
            font-family: 'Nunito', sans-serif; flex: 1;
        }
        .coup-in::placeholder { color: rgba(255,255,255,.22); }
        .coup-in:focus { border-color: var(--amber); }
        .coup-btn {
            background: transparent; border: 1px solid var(--amber); color: var(--amber);
            border-radius: 7px; padding: 7px 10px; font-size: 11px; font-weight: 800;
            cursor: pointer; font-family: 'Nunito', sans-serif; white-space: nowrap;
        }
        .coup-btn:hover { background: var(--amber); color: #fff; }

        .row-sum { display: flex; justify-content: space-between; align-items: center; padding: 3px 0; }
        .lbl { color: rgba(255,255,255,.38); font-size: 11px; }
        .val { color: rgba(255,255,255,.72); font-size: 11px; font-weight: 600; }
        .val-disc { color: var(--green); font-size: 11px; font-weight: 700; }
        .sep { border: none; border-top: 1px dashed rgba(255,255,255,.1); margin: 5px 0; }
        .grand-lbl { color: #fff; font-size: 13px; font-weight: 800; }
        .grand-val { font-family: 'Playfair Display', serif; color: var(--amber); font-size: 20px; }

        .btn-pay {
            background: var(--amber); border: none; border-radius: 9px; color: #fff;
            font-size: 13px; font-weight: 800; font-family: 'Nunito', sans-serif; padding: 11px;
            transition: background .13s; display: flex; align-items: center; justify-content: center; gap: 7px;
        }
        .btn-pay:hover { background: var(--amber2); }
        .btn-cancel {
            background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.22); border-radius: 9px;
            color: #f87171; font-size: 11px; font-weight: 700; font-family: 'Nunito', sans-serif;
            padding: 11px 13px; display: flex; align-items: center; justify-content: center; gap: 5px;
        }
        .btn-cancel:hover { background: rgba(239,68,68,.2); }

        /* === TOAST === */
        .toast-pos { position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%); z-index: 9999; pointer-events: none; }
        .toast-inner {
            background: #1e293b; color: #fff; padding: 9px 18px; border-radius: 30px;
            font-size: 12px; font-weight: 700; box-shadow: 0 4px 18px rgba(0,0,0,.2);
            white-space: nowrap; opacity: 0; transition: all .25s; transform: translateY(8px);
        }
        .toast-pos.show .toast-inner { opacity: 1; transform: translateY(0); }

        /* === MODALS === */
        .modal-content { border-radius: 18px; border: none; box-shadow: 0 16px 50px rgba(0,0,0,.16); }
        .m-title { font-family: 'Playfair Display', serif; font-size: 19px; color: #1e293b; text-align: center; }
        .m-amount { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 800; color: var(--amber2); text-align: center; }
        .pay-opt {
            border: 2px solid var(--border); border-radius: 12px; padding: 12px 6px;
            text-align: center; cursor: pointer; font-size: 12px; font-weight: 700; color: #64748b;
            transition: all .13s; font-family: 'Nunito', sans-serif;
        }
        .pay-opt:hover { border-color: var(--amber); color: var(--amber2); }
        .pay-opt.active { border-color: var(--amber); background: var(--cream); color: var(--amber2); }
        .pay-icon { font-size: 22px; margin-bottom: 5px; }
        .btn-confirm {
            background: var(--amber); border: none; border-radius: 9px; color: #fff;
            font-size: 13px; font-weight: 800; font-family: 'Nunito', sans-serif;
            padding: 11px 20px; display: flex; align-items: center; gap: 7px; transition: background .13s;
        }
        .btn-confirm:hover { background: var(--amber2); }
        .btn-back {
            background: #f1f5f9; border: none; border-radius: 9px; color: #64748b;
            font-size: 12px; font-weight: 700; font-family: 'Nunito', sans-serif; padding: 11px 16px;
        }

        /* === VARIANT MODAL === */
        .variant-item {
            border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 12px;
            cursor: pointer; transition: all .13s; font-size: 12px; font-weight: 700; color: #64748b;
        }
        .variant-item:hover, .variant-item.selected { border-color: var(--amber); background: var(--cream); color: var(--amber2); }
        .no-variant-btn {
            border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 12px;
            cursor: pointer; transition: all .13s; font-size: 12px; font-weight: 700; color: #64748b;
            background: #fff; width: 100%; text-align: left;
        }
        .no-variant-btn:hover { border-color: #94a3b8; }

        /* === SUCCESS === */
        .success-icon { width: 60px; height: 60px; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 26px; color: #fff; margin: 0 auto; }
    </style>
</head>
<body>

    <!-- ===== TOPBAR ===== -->
    <div class="topbar d-flex align-items-center justify-content-between px-3">
        <div class="d-flex align-items-center gap-2">
            <div class="logo-box">☕</div>
            <span class="brand-name">PolyCafe</span>
            <span class="pos-tag">POS</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="clock-box d-flex align-items-center gap-2">
                <i class="fa fa-clock" style="color:var(--amber)"></i>
                <span id="clock">--:--:--</span>
            </div>
            <div class="staff-box d-flex align-items-center gap-2">
                <span class="staff-dot"></span>
                <i class="fa fa-user-tie" style="color:#64748b;font-size:11px"></i>
                Nhân viên
            </div>
            <button class="bill-toggle-btn" onclick="toggleBill()">
                <i class="fa fa-receipt"></i>Hóa đơn
                <span class="bill-badge" id="bill-badge" style="display:none">0</span>
            </button>
        </div>
    </div>

    <!-- ===== BODY ===== -->
    <div class="app-body">

        <!-- ===== LEFT: MENU ===== -->
        <div class="left-col" id="left-col">
            <div class="toolbar-wrap">
                <div class="search-wrap">
                    <i class="fa fa-magnifying-glass"></i>
                    <input id="search" placeholder="Tìm kiếm món..." oninput="filterCards()" />
                </div>
            </div>

            <!-- Category Bar -->
            <div class="cat-bar" id="cat-bar">
                <button class="cat-btn active" data-cat="all" onclick="setCategory(this)">
                    <i class="fa fa-border-all"></i>Tất cả
                </button>
                @foreach (var cat in categories)
                {
                    <button class="cat-btn" data-cat="@cat.Id" onclick="setCategory(this)">
                        <i class="fa fa-mug-hot"></i>@cat.Name
                    </button>
                }
            </div>

            <!-- Product Grid -->
            <div class="product-scroll">
                <div class="row g-2" id="product-grid">
                    @foreach (var drink in Model)
                    {
                        var hasVariants = drink.DrinkVariants != null && drink.DrinkVariants.Any();
                        var variantsJson = hasVariants
                        ? System.Text.Json.JsonSerializer.Serialize(drink.DrinkVariants!.Select(v => new { id = v.Id, name = v.VariantName, extra = v.ExtraPrice }))
                        : "[]";

                        <div class="col-3 p-col"
                             data-cat="@drink.CategoryId"
                             data-name="@drink.Name.ToLower()"
                             data-desc="@(drink.Description?.ToLower() ?? "")">
                            <div class="p-card"
                                 onclick="cardClick('@drink.Id','@drink.Name',@drink.Price,'@(drink.Description ?? "")',@variantsJson)"
                                 id="card-@drink.Id">
                                <div class="p-img" style="background:#fef3c7">
                                    ☕
                                    <span class="p-qty-badge" id="badge-@drink.Id" style="display:none">0</span>
                                </div>
                                <div class="p-body">
                                    <div class="p-name">@drink.Name</div>
                                    <div class="p-desc">@drink.Description</div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="p-price">@drink.Price.ToString("N0")đ</span>
                                        <button class="p-add-btn"
                                                onclick="event.stopPropagation();cardClick('@drink.Id','@drink.Name',@drink.Price,'@(drink.Description ?? "")',@variantsJson)">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ===== RIGHT: BILL SIDEBAR ===== -->
        <div class="sidebar" id="sb">
            <div class="sb-inner">
                <div class="sb-head d-flex justify-content-between align-items-center">
                    <span class="sb-title"><i class="fa fa-receipt me-2" style="color:var(--amber)"></i>Hóa Đơn</span>
                    <span class="sb-num" id="onum">#001</span>
                </div>

                <div class="order-scroll" id="olist">
                    <div class="empty-bill" id="empty-bill">
                        <i class="fa fa-cart-shopping"></i>Chưa có món nào
                    </div>
                </div>

                <div class="sb-foot">
                    <div class="d-flex gap-2 mb-2">
                        <input class="coup-in" id="coup" placeholder="Nhập mã khuyến mãi..." />
                        <button class="coup-btn" onclick="apCoup()"><i class="fa fa-tag me-1"></i>Áp</button>
                    </div>
                    <div class="row-sum"><span class="lbl">Tạm tính</span><span class="val" id="sub">0đ</span></div>
                    <div class="row-sum" id="drow" style="display:none">
                        <span class="lbl"><i class="fa fa-percent me-1" style="color:var(--green)"></i><span id="dlbl">Giảm giá</span></span>
                        <span class="val-disc" id="dval">−0đ</span>
                    </div>
                    <hr class="sep" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="grand-lbl">Tổng tiền</span>
                        <span class="grand-val" id="tot">0đ</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-pay flex-fill" onclick="openPayModal()">
                            <i class="fa fa-credit-card"></i> Thanh Toán
                        </button>
                        <button class="btn-cancel" onclick="clrAll()">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== TOAST ===== -->
    <div class="toast-pos" id="toast-pos">
        <div class="toast-inner" id="toast-inner"></div>
    </div>

    <!-- ===== VARIANT MODAL ===== -->
    <div class="modal fade" id="variantModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">
                <div class="m-title mb-1">
                    <i class="fa fa-sliders me-2" style="color:var(--amber)"></i>
                    <span id="vm-name">Chọn tùy chọn</span>
                </div>
                <div class="text-center text-muted mb-3" style="font-size:12px;">
                    Giá gốc: <span id="vm-baseprice" style="color:var(--amber2);font-weight:700"></span>
                </div>
                <div id="vm-variants" class="d-flex flex-column gap-2 mb-3"></div>
                <div class="d-flex gap-2">
                    <button class="btn-back" data-bs-dismiss="modal"><i class="fa fa-arrow-left me-1"></i>Quay lại</button>
                    <button class="btn-confirm flex-fill" onclick="confirmVariant()">
                        <i class="fa fa-plus me-1"></i>Thêm vào đơn
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== PAYMENT MODAL ===== -->
    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">
                <div class="m-title mb-1">
                    <i class="fa fa-receipt me-2" style="color:var(--amber)"></i>Thanh toán
                </div>
                <div class="text-center text-muted mb-3" style="font-size:12px;">Chọn phương thức thanh toán</div>
                <div class="m-amount mb-3" id="ma">0đ</div>
                <div class="row g-2 mb-3">
                    <div class="col-4">
                        <div class="pay-opt active" onclick="selPay(this)" data-method="cash">
                            <div class="pay-icon"><i class="fa fa-money-bill-wave" style="color:#22c55e"></i></div>
                            Tiền mặt
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="pay-opt" onclick="selPay(this)" data-method="transfer">
                            <div class="pay-icon"><i class="fa fa-qrcode" style="color:#3b82f6"></i></div>
                            Chuyển khoản
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="pay-opt" onclick="selPay(this)" data-method="voucher">
                            <div class="pay-icon"><i class="fa fa-gift" style="color:#f59e0b"></i></div>
                            Voucher
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-back" data-bs-dismiss="modal"><i class="fa fa-arrow-left me-1"></i>Quay lại</button>
                    <button class="btn-confirm flex-fill" onclick="confirmPayment()">
                        <i class="fa fa-check me-1"></i>Xác nhận thanh toán
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== SUCCESS MODAL ===== -->
    <div class="modal fade" id="successModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content p-4 text-center">
                <div class="success-icon mb-3"><i class="fa fa-check"></i></div>
                <div class="m-title mb-1">Thanh toán thành công!</div>
                <div class="text-muted mb-1" style="font-size:12px;">Mã đơn hàng</div>
                <div style="font-size:16px;font-weight:800;color:var(--amber2)" id="success-orderId"></div>
                <div class="text-muted mt-1" style="font-size:12px;">Tổng: <span id="success-total" style="color:var(--green);font-weight:700"></span></div>
                <button class="btn-confirm w-100 mt-3 justify-content-center" onclick="closeSuccess()">
                    <i class="fa fa-plus me-1"></i>Đơn mới
                </button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ========== STATE ==========
        let cart = {}; // { key: { drinkId, variantId, name, variantName, price, qty } }
        let discount = 0;
        let discountType = '';
        let discountValue = 0;
        let voucherCode = '';
        let orderCount = 1;
        let billVisible = true;

        // Pending variant selection
        let pendingDrink = null;
        let selectedVariantId = null;
        let selectedVariantExtra = 0;
        let selectedVariantName = '';

        const bsVariantModal = new bootstrap.Modal(document.getElementById('variantModal'));
        const bsPayModal = new bootstrap.Modal(document.getElementById('payModal'));
        const bsSuccessModal = new bootstrap.Modal(document.getElementById('successModal'));

        // ========== CATEGORY FILTER ==========
        function setCategory(btn) {
            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterCards();
        }

        function filterCards() {
            const q = document.getElementById('search').value.toLowerCase();
            const activeCat = document.querySelector('.cat-btn.active')?.dataset.cat || 'all';
            document.querySelectorAll('.p-col').forEach(col => {
                const matchCat = activeCat === 'all' || col.dataset.cat === activeCat;
                const matchQ = col.dataset.name.includes(q) || col.dataset.desc.includes(q);
                col.style.display = (matchCat && matchQ) ? '' : 'none';
            });
        }

        // ========== ADD TO CART ==========
        function cardClick(id, name, price, desc, variants) {
            if (variants && variants.length > 0) {
                openVariantModal(id, name, price, variants);
            } else {
                addToCart(id, null, name, null, price);
            }
            if (!billVisible) {
                billVisible = true;
                document.getElementById('sb').classList.remove('hidden');
            }
        }

        function openVariantModal(id, name, price, variants) {
            pendingDrink = { id, name, price, variants };
            selectedVariantId = null;
            selectedVariantExtra = 0;
            selectedVariantName = '';

            document.getElementById('vm-name').textContent = name;
            document.getElementById('vm-baseprice').textContent = price.toLocaleString('vi') + 'đ';

            const container = document.getElementById('vm-variants');
            container.innerHTML = '';

            // No variant option
            const noVar = document.createElement('div');
            noVar.className = 'no-variant-btn';
            noVar.innerHTML = `<i class="fa fa-circle-dot me-2" style="color:#94a3b8"></i>Mặc định — <b>${price.toLocaleString('vi')}đ</b>`;
            noVar.onclick = () => {
                container.querySelectorAll('.variant-item').forEach(x => x.classList.remove('selected'));
                noVar.style.borderColor = 'var(--amber)';
                noVar.style.background = 'var(--cream)';
                selectedVariantId = null;
                selectedVariantExtra = 0;
                selectedVariantName = '';
            };
            container.appendChild(noVar);

            variants.forEach(v => {
                const el = document.createElement('div');
                el.className = 'variant-item d-flex justify-content-between';
                el.innerHTML = `<span>${v.name}</span><span style="color:var(--amber2);font-weight:800">+${v.extra.toLocaleString('vi')}đ → ${(price + v.extra).toLocaleString('vi')}đ</span>`;
                el.onclick = () => {
                    container.querySelectorAll('.variant-item').forEach(x => x.classList.remove('selected'));
                    noVar.style.borderColor = '';
                    noVar.style.background = '';
                    el.classList.add('selected');
                    selectedVariantId = v.id;
                    selectedVariantExtra = v.extra;
                    selectedVariantName = v.name;
                };
                container.appendChild(el);
            });

            bsVariantModal.show();
        }

        function confirmVariant() {
            if (!pendingDrink) return;
            const finalPrice = pendingDrink.price + selectedVariantExtra;
            addToCart(pendingDrink.id, selectedVariantId, pendingDrink.name, selectedVariantName, finalPrice);
            bsVariantModal.hide();
            pendingDrink = null;
        }

        function addToCart(drinkId, variantId, name, variantName, price) {
            const key = drinkId + (variantId || '');
            if (!cart[key]) {
                cart[key] = { drinkId, variantId, name, variantName, price, qty: 0 };
            }
            cart[key].qty++;
            renderCart();
            updateBadge(drinkId);
            toast('<i class="fa fa-check me-1"></i>' + name + (variantName ? ' (' + variantName + ')' : ''));
            recalcDiscount();
        }

        function changeQty(key, delta) {
            if (!cart[key]) return;
            cart[key].qty += delta;
            if (cart[key].qty <= 0) {
                delete cart[key];
            }
            renderCart();
            recalcAllBadges();
            recalcDiscount();
        }

        function removeItem(key) {
            delete cart[key];
            renderCart();
            recalcAllBadges();
            recalcDiscount();
        }

        // ========== RENDER CART ==========
        function renderCart() {
            const items = Object.entries(cart);
            const list = document.getElementById('olist');

            if (!items.length) {
                list.innerHTML = '<div class="empty-bill"><i class="fa fa-cart-shopping"></i>Chưa có món nào</div>';
                updateTotal();
                return;
            }

            list.innerHTML = items.map(([key, item]) => `
                <div class="oi">
                    <div class="oi-em">☕</div>
                    <div class="flex-fill" style="min-width:0">
                        <div class="oi-name">${item.name}</div>
                        ${item.variantName ? `<div class="oi-sub">${item.variantName}</div>` : ''}
                        <div class="oi-price">${(item.price * item.qty).toLocaleString('vi')}đ</div>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <button class="qbtn" onclick="changeQty('${key}',-1)"><i class="fa fa-minus"></i></button>
                        <span class="qnum">${item.qty}</span>
                        <button class="qbtn" onclick="changeQty('${key}',1)"><i class="fa fa-plus"></i></button>
                    </div>
                    <button class="del-btn" onclick="removeItem('${key}')"><i class="fa fa-xmark"></i></button>
                </div>
            `).join('');

            updateTotal();
        }

        function updateTotal() {
            const subtotal = Object.values(cart).reduce((a, i) => a + i.price * i.qty, 0);
            document.getElementById('sub').textContent = subtotal.toLocaleString('vi') + 'đ';
            document.getElementById('tot').textContent = Math.max(0, subtotal - discount).toLocaleString('vi') + 'đ';
        }

        function updateBadge(drinkId) {
            const total = Object.entries(cart)
                .filter(([k]) => k.startsWith(drinkId))
                .reduce((a, [, v]) => a + v.qty, 0);
            const badge = document.getElementById('badge-' + drinkId);
            if (badge) {
                if (total > 0) { badge.style.display = 'flex'; badge.textContent = total; }
                else badge.style.display = 'none';
            }
        }

        function recalcAllBadges() {
            document.querySelectorAll('[id^="badge-"]').forEach(b => {
                const drinkId = b.id.replace('badge-', '');
                updateBadge(drinkId);
            });
        }

        function updBadge() {
            const t = Object.values(cart).reduce((a, i) => a + i.qty, 0);
            const b = document.getElementById('bill-badge');
            if (t > 0) { b.style.display = 'flex'; b.textContent = t; }
            else b.style.display = 'none';
        }

        function renderCart() {
            const items = Object.entries(cart);
            const list = document.getElementById('olist');
            if (!items.length) {
                list.innerHTML = '<div class="empty-bill"><i class="fa fa-cart-shopping"></i>Chưa có món nào</div>';
            } else {
                list.innerHTML = items.map(([key, item]) => `
                    <div class="oi">
                        <div class="oi-em">☕</div>
                        <div class="flex-fill" style="min-width:0">
                            <div class="oi-name">${item.name}</div>
                            ${item.variantName ? `<div class="oi-sub">${item.variantName}</div>` : ''}
                            <div class="oi-price">${(item.price * item.qty).toLocaleString('vi')}đ</div>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <button class="qbtn" onclick="changeQty('${key}',-1)"><i class="fa fa-minus"></i></button>
                            <span class="qnum">${item.qty}</span>
                            <button class="qbtn" onclick="changeQty('${key}',1)"><i class="fa fa-plus"></i></button>
                        </div>
                        <button class="del-btn" onclick="removeItem('${key}')"><i class="fa fa-xmark"></i></button>
                    </div>
                `).join('');
            }
            updateTotal();
            updBadge();
        }

        // ========== VOUCHER ==========
        function apCoup() {
            const code = document.getElementById('coup').value.trim();
            if (!code) { toast('❌ Nhập mã khuyến mãi'); return; }

            fetch(`/Order/CheckVoucher?code=${encodeURIComponent(code)}`)
                .then(r => r.json())
                .then(data => {
                    if (data.valid) {
                        voucherCode = code;
                        discountType = data.discountType;
                        discountValue = data.discountValue;
                        recalcDiscount();
                        toast('🎉 ' + data.message);
                    } else {
                        discount = 0; voucherCode = '';
                        document.getElementById('drow').style.display = 'none';
                        updateTotal();
                        toast('❌ ' + data.message);
                    }
                });
        }

        function recalcDiscount() {
            if (!voucherCode) return;
            const subtotal = Object.values(cart).reduce((a, i) => a + i.price * i.qty, 0);
            if (discountType === 'percent') discount = Math.round(subtotal * discountValue / 100);
            else discount = discountValue;

            document.getElementById('drow').style.display = 'flex';
            document.getElementById('dlbl').textContent = discountType === 'percent' ? `Giảm ${discountValue}%` : 'Giảm giá';
            document.getElementById('dval').textContent = '−' + discount.toLocaleString('vi') + 'đ';
            updateTotal();
        }

        // ========== CLEAR ==========
        function clrAll() {
            cart = {}; discount = 0; voucherCode = ''; discountType = ''; discountValue = 0;
            document.getElementById('coup').value = '';
            document.getElementById('drow').style.display = 'none';
            renderCart();
            recalcAllBadges();
        }

        // ========== TOGGLE BILL ==========
        function toggleBill() {
            billVisible = !billVisible;
            document.getElementById('sb').classList.toggle('hidden', !billVisible);
        }

        // ========== PAYMENT ==========
        function openPayModal() {
            const subtotal = Object.values(cart).reduce((a, i) => a + i.price * i.qty, 0);
            if (!subtotal) { toast('<i class="fa fa-triangle-exclamation me-1"></i>Chưa có món'); return; }
            const total = Math.max(0, subtotal - discount);
            document.getElementById('ma').textContent = total.toLocaleString('vi') + 'đ';
            bsPayModal.show();
        }

        function selPay(el) {
            document.querySelectorAll('.pay-opt').forEach(x => x.classList.remove('active'));
            el.classList.add('active');
        }

        function confirmPayment() {
            bsPayModal.hide();

            const items = Object.values(cart).map(i => ({
                drinkId: i.drinkId,
                variantId: i.variantId || null,
                quantity: i.qty
            }));

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            fetch('/Order/CreateOrder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ items, voucherCode: voucherCode || null })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    orderCount++;
                    document.getElementById('onum').textContent = '#' + String(orderCount).padStart(3, '0');
                    document.getElementById('success-orderId').textContent = data.orderId;
                    document.getElementById('success-total').textContent = data.total.toLocaleString('vi') + 'đ';
                    bsSuccessModal.show();
                } else {
                    toast('❌ ' + (data.message || 'Có lỗi xảy ra'));
                }
            })
            .catch(() => {
                // Fallback nếu chưa kết nối DB: vẫn hiện thành công UI
                orderCount++;
                document.getElementById('onum').textContent = '#' + String(orderCount).padStart(3, '0');
                const total = Math.max(0, Object.values(cart).reduce((a, i) => a + i.price * i.qty, 0) - discount);
                document.getElementById('success-orderId').textContent = 'ORD' + Date.now();
                document.getElementById('success-total').textContent = total.toLocaleString('vi') + 'đ';
                bsSuccessModal.show();
            });
        }

        function closeSuccess() {
            bsSuccessModal.hide();
            clrAll();
        }

        // ========== TOAST ==========
        let toastTimer;
        function toast(msg) {
            const pos = document.getElementById('toast-pos');
            document.getElementById('toast-inner').innerHTML = msg;
            pos.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => pos.classList.remove('show'), 2200);
        }

        // ========== CLOCK ==========
        setInterval(() => {
            document.getElementById('clock').textContent =
                new Date().toLocaleTimeString('vi', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }, 1000);
    </script>
</body>
</html> *@
@* @model IEnumerable<Web_QuanLy_PolyCafe.Models.Drink>
@{
    ViewData["Title"] = "Đặt Món";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categories = ViewBag.Categories as IEnumerable<Web_QuanLy_PolyCafe.Models.Category>
                     ?? Enumerable.Empty<Web_QuanLy_PolyCafe.Models.Category>();

    var drinksJson = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => new
    {
        id = d.Id,
        name = d.Name,
        desc = d.Description ?? "",
        price = d.Price,
        catId = d.CategoryId,
        variants = (d.DrinkVariants ?? new List<Web_QuanLy_PolyCafe.Models.DrinkVariant>())
                    .Where(v => v.IsActive)
                    .Select(v => new { id = v.Id, name = v.VariantName, extra = v.ExtraPrice })
    }));

    var catsJson = System.Text.Json.JsonSerializer.Serialize(
        categories.Select(c => new { id = c.Id, name = c.Name })
    );
}

