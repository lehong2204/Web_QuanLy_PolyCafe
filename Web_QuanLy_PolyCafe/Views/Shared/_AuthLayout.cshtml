<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PolyCafe</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --amber: #f59e0b;
            --amber2: #d97706;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #f1f5f9;
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ===== HEADER ===== */
        .auth-header {
            height: 64px;
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            flex-shrink: 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .auth-logo-box {
            width: 36px;
            height: 36px;
            background: var(--amber);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .auth-logo-box img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .auth-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            color: #1e293b;
            font-weight: 700;
        }

        .auth-brand-tag {
            background: #fef3c7;
            color: var(--amber2);
            font-size: 10px;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 20px;
        }

        /* ===== MAIN ===== */
        main {
            flex: 1;
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .auth-row {
            min-height: 480px;
        }

        /* LEFT BRAND PANEL */
        .auth-brand-panel {
            background: rgba(255,255,255,.12);
            border-radius: 20px;
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,.2);
        }

        .auth-logo-circle {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 32px rgba(0,0,0,.2);
            border: 4px solid rgba(255,255,255,.6);
            margin-bottom: 24px;
            overflow: hidden;
        }

            .auth-logo-circle img {
                width: 85%;
                height: 85%;
                object-fit: contain;
            }

        .auth-brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            color: #fff;
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-brand-sub {
            color: rgba(255,255,255,.85);
            font-size: 15px;
            text-align: center;
        }

        /* RIGHT CARD */
        .auth-card {
            background: #fff;
            width: 100%;
            max-width: 420px;
            padding: 36px 32px;
            border-radius: 16px;
            box-shadow: 0 16px 48px rgba(0,0,0,.18);
        }

        /* FORM CONTROLS */
        .form-control {
            font-family: 'Nunito', sans-serif;
            font-size: 14px;
            border-color: #e2e8f0;
            border-radius: 9px;
            padding: 10px 14px;
            transition: border-color .15s, box-shadow .15s;
        }

            .form-control:focus {
                border-color: var(--amber);
                box-shadow: 0 0 0 3px rgba(245,158,11,.15);
            }

        .input-group .form-control {
            border-right: none;
        }

        .input-group .input-group-text {
            border-color: #e2e8f0;
            border-left: none;
            border-radius: 0 9px 9px 0;
        }

        .btn-main {
            background: var(--amber);
            color: #fff;
            font-weight: 700;
            font-family: 'Nunito', sans-serif;
            border: none;
            border-radius: 9px;
            padding: 11px;
            font-size: 14px;
            transition: background .13s;
        }

            .btn-main:hover {
                background: var(--amber2);
                color: #fff;
            }

        /* ===== FOOTER ===== */
        .auth-footer {
            background: #1e293b;
            color: #94a3b8;
            padding: 20px 0;
            font-size: 13px;
            text-align: center;
            flex-shrink: 0;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="auth-header">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <!-- LOGO từ file ảnh -->
                <div class="auth-logo-box">
                    <img src="~/images/logo.png" alt="PolyCafe Logo" />
                </div>
                <span class="auth-brand-name">PolyCafe</span>
                <span class="auth-brand-tag">POS</span>
            </div>
        </div>
    </header>

    <!-- CONTENT -->
    <main>
        <div class="container">
            <div class="row align-items-center justify-content-center auth-row g-4">

                <!-- LEFT: BRAND PANEL -->
                <div class="col-lg-5 d-none d-lg-flex">
                    <div class="auth-brand-panel w-100">
                        <div class="auth-logo-circle">
                            <img src="~/images/logo.png" alt="PolyCafe Logo" />
                        </div>
                        <div class="auth-brand-title">PolyCafe</div>
                        <p class="auth-brand-sub">Hệ thống quản lý quán cà phê<br />thông minh & hiện đại</p>
                    </div>
                </div>

                <!-- RIGHT: FORM CARD -->
                <div class="col-lg-5 col-md-8 col-sm-10 d-flex justify-content-center">
                    <div class="auth-card">
                        @RenderBody()
                    </div>
                </div>

            </div>
        </div>
    </main>

    <footer class="auth-footer"></footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

