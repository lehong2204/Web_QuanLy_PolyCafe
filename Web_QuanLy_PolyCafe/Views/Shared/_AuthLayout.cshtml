            background: #1e293b;
            color: #94a3b8;
            padding: 20px 0;
            font-size: 13px;
            text-align: center;
            flex-shrink: 0;
        }

            .auth-footer a {
                color: #94a3b8;
                text-decoration: none;
                margin: 0 10px;
            }

                .auth-footer a:hover {
                    color: var(--amber);
                }
    </style>
</head>
<body>

