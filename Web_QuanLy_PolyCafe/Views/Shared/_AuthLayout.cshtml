        .auth-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            color: #1e293b;
            font-weight: 700;
        }

        .auth-brand-tag {
            background: #fef3c7;
            color: var(--amber2);
            font-size: 10px;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 20px;
        }

        /* ===== MAIN AUTH PAGE ===== */
        main {
            flex: 1;
            background: var(--amber);
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .auth-row {
            min-height: 480px;
        }

        /* LEFT BRAND PANEL */
        .auth-brand-panel {
            background: rgba(255,255,255,.12);
            border-radius: 20px;
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,.2);
        }

        .auth-logo-circle {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: #fff;
            display: flex;
