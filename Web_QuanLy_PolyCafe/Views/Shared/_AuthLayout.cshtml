            margin-bottom: 24px;
        }

        .auth-brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            color: #fff;
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-brand-sub {
            color: rgba(255,255,255,.85);
            font-size: 15px;
            text-align: center;
        }

        /* RIGHT CARD */
        .auth-card {
            background: #fff;
            width: 100%;
            max-width: 420px;
            padding: 36px 32px;
            border-radius: 16px;
            box-shadow: 0 16px 48px rgba(0,0,0,.18);
        }

        /* FORM CONTROLS */
        .form-control {
            font-family: 'Nunito', sans-serif;
            font-size: 14px;
            border-color: #e2e8f0;
            border-radius: 9px;
            padding: 10px 14px;
            transition: border-color .15s, box-shadow .15s;
        }

            .form-control:focus {
                border-color: var(--amber);
                box-shadow: 0 0 0 3px rgba(245,158,11,.15);
            }

        .input-group .form-control {
            border-right: none;
        }

        .input-group .input-group-text {
            border-color: #e2e8f0;
            border-left: none;
            border-radius: 0 9px 9px 0;
        }

